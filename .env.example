# --- LLM provider keys (optional at runtime; the UI Settings page also accepts
# session-only keys that override these and are NEVER stored in the database) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=

# Default LLM provider for agents: anthropic | openai | groq
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-7

# --- Search provider ---
TAVILY_API_KEY=
SEARCH_PROVIDER=tavily

# --- Supabase (required when SUPABASE_ENABLED=true) ---
SUPABASE_ENABLED=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Use the service role key ONLY in trusted server contexts. Never expose to clients.
SUPABASE_SERVICE_ROLE_KEY=

# --- App ---
APP_ENV=local
LOG_LEVEL=INFO
DEFAULT_POSTING_MAX_AGE_DAYS=14
HTTP_TIMEOUT_SECONDS=15
HTTP_USER_AGENT=ExecutiveJobScout/0.1 (+local-run)
